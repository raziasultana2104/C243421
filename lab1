#include <iostream>

using namespace std;
int linearSearch(int arr[], int n, int val);
void inputArray(int arr[], int n);
int main()
{
    int n = 0;
    cin >> n;
    int arr[n];
    inputArray(arr, n);
    int val;
    cin >> val;
    int index = linearSearch(arr, n, val);
    if(index == -1)
    {
        cout<<"not found\n";
    }
    else
    {
        cout<<index+1;
    }
    return 0;
}
int linearSearch(int arr[], int n, int val)
{
    int index = -1;
    for (int i = 0; i < n; i++)
    {
        if (arr[i] == val)
        {
            index = i;
            break;
        }
    }
    return index;
}
void inputArray(int arr[], int n)
{
    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }
}
